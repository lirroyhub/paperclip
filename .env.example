# Paperclip stack environment — TEMPLATE
# ---------------------------------------
# Copy this file to `.env` and fill in real values.
# The real `.env` is git-ignored and must NEVER be committed.
#
#   cp .env.example .env
#   then edit the values below

# --- Auth (required) --------------------------------------------------------
# Paperclip refuses to start without this. Generate a strong random value:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32

# --- Postgres ---------------------------------------------------------------
# Used by both the db service and the connection string.
#   openssl rand -hex 16
POSTGRES_PASSWORD=replace-with-a-strong-password

# --- Public URL -------------------------------------------------------------
# Local default. Change only if you front it with a tunnel/reverse proxy.
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# --- Paperclip image --------------------------------------------------------
# Official image. Pin to a specific release tag for stability (recommended)
# instead of :latest. Tags: https://github.com/paperclipai/paperclip/pkgs/container/paperclip
PAPERCLIP_IMAGE=ghcr.io/paperclipai/paperclip:latest

# --- Model provider key (use whichever your agents need) --------------------
# Paperclip orchestrates agents that call an LLM provider.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Backup service ---------------------------------------------------------
# Name of the rclone remote you configure (see README).
RCLONE_REMOTE=gdrive
# Folder path inside the remote (Google Drive).
RCLONE_DEST_PATH=paperclip-backups
# Days of dated backups to keep before pruning.
RETENTION_DAYS=30
# Timezone for the backup schedule (and container clock).
TZ=America/Montevideo
